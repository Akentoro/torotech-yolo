{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DetectResponse",
  "description": "POST /detect JSON response — v2（新增 class_id, model_version, image_size, bbox width/height）",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "project": { "type": "string" },
    "model_version": {
      "type": "string",
      "description": "使用的模型版本 (e.g. 'v1', 'v2')，用於追蹤和 A/B 比對"
    },
    "count": { "type": "integer", "minimum": 0 },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class_id": { "type": "integer", "description": "類別 index (0-based)" },
          "class_name": { "type": "string", "description": "類別名稱（原 'class' 欄位改名避免 C# 保留字）" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox": {
            "type": "object",
            "properties": {
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" }
            },
            "required": ["x1", "y1", "x2", "y2"]
          },
          "center_x": { "type": "number" },
          "center_y": { "type": "number" },
          "width": { "type": "number", "description": "bbox 寬度 (px)" },
          "height": { "type": "number", "description": "bbox 高度 (px)" }
        },
        "required": ["class_id", "class_name", "confidence", "bbox", "center_x", "center_y", "width", "height"]
      }
    },
    "image_size": {
      "type": "object",
      "description": "原始圖片尺寸",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["width", "height"]
    },
    "inference_ms": { "type": "number" },
    "error": { "type": "string" }
  },
  "required": ["success"],
  "_changelog": {
    "v2": [
      "RENAMED: 'class' → 'class_name'（避免 C# 保留字衝突）",
      "ADDED: 'class_id' — 類別 index，方便 switch/lookup",
      "ADDED: 'model_version' — 追蹤用哪個版本推論",
      "ADDED: 'image_size' — 原始圖片尺寸（pixel→robot 座標轉換需要）",
      "ADDED: 'width', 'height' — bbox 尺寸（省去 C# 端計算）",
      "PARAMS: project/confidence/version 改為 Form field（非 Query param）"
    ]
  }
}
