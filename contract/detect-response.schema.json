{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DetectResponse",
  "description": "POST /detect JSON response — v3 (pure YOLO, no OpenCV fields)",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "project": { "type": "string" },
    "model_version": { "type": "string", "description": "模型版本 (e.g. 'v1', 'v2')" },
    "count": { "type": "integer", "minimum": 0 },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class_id": { "type": "integer", "description": "類別 index (0-based)" },
          "class_name": { "type": "string", "description": "類別名稱" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox": {
            "type": "object",
            "properties": {
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" }
            },
            "required": ["x1", "y1", "x2", "y2"]
          },
          "center_x": { "type": "number" },
          "center_y": { "type": "number" },
          "width": { "type": "number", "description": "bbox 寬度 (px)" },
          "height": { "type": "number", "description": "bbox 高度 (px)" }
        },
        "required": ["class_id", "class_name", "confidence", "bbox", "center_x", "center_y", "width", "height"]
      }
    },
    "image_size": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["width", "height"]
    },
    "inference_ms": { "type": "number" },
    "error": { "type": "string" }
  },
  "required": ["success"],
  "_changelog": {
    "v2": [
      "RENAMED: 'class' → 'class_name'",
      "ADDED: 'class_id', 'model_version', 'image_size', 'width', 'height'",
      "PARAMS: project/confidence/version 改為 Form field"
    ],
    "v2.1": [
      "ADDED: 'angle', 'contour_area', 'rectangularity', 'refined' (OpenCV refine)"
    ],
    "v3": [
      "REMOVED: 'angle', 'contour_area', 'rectangularity', 'refined'",
      "REASON: YOLO Service 回歸純 YOLO — OpenCV 精修改由 VisionFlow 處理",
      "NOTE: 走 VisionFlow TCP 路徑的設備端不受影響（VisionFlow 回傳包含精修欄位）",
      "NOTE: 直打 YOLO /detect 的設備端需更新 DTO（移除 4 個欄位）"
    ]
  }
}
