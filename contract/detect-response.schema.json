{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DetectResponse",
  "description": "POST /detect JSON response",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "project": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox": {
            "type": "object",
            "properties": {
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" }
            },
            "required": ["x1", "y1", "x2", "y2"]
          },
          "center_x": { "type": "number" },
          "center_y": { "type": "number" }
        },
        "required": ["class", "confidence", "bbox", "center_x", "center_y"]
      }
    },
    "inference_ms": { "type": "number" },
    "error": { "type": "string" }
  },
  "required": ["success"]
}
